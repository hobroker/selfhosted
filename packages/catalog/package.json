{
  "name": "@hobroker/selfhosted-catalog",
  "version": "1.0.0",
  "description": "Catalog generator — scans app READMEs and injects markdown tables into the root README",
  "author": "Igor Leahu <igor.leahu24@gmail.com>",
  "type": "module",
  "scripts": {
    "generate": "vite-node src/cli.ts",
    "generate:check": "vite-node src/cli.ts --check",
    "generate:dry": "vite-node src/cli.ts --dry-run",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.15",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "vite": "^8.0.0",
    "vite-node": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
