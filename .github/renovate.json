{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommitTypeAll(chore)", "schedule:monthly"],
  "assignees": ["hobroker"],
  "platformAutomerge": false,
  "separateMajorMinor": false,
  "separateMultipleMajor": false,
  "packageRules": [
    {
      "matchFileNames": ["packages/cli/**"],
      "groupName": "NPM cli package"
    },
    {
      "matchFileNames": ["packages/catalog/**"],
      "groupName": "NPM catalog package"
    },
    {
      "matchManagers": ["npm"],
      "groupName": "NPM packages"
    },
    {
      "matchManagers": ["helm-values", "argocd", "helmv3"],
      "groupName": "Apps"
    },
    {
      "matchFileNames": ["apps/automation/**"],
      "groupName": "automation"
    },
    {
      "matchFileNames": ["apps/media/**"],
      "groupName": "media"
    },
    {
      "matchFileNames": ["apps/monitoring/**"],
      "groupName": "monitoring"
    },
    {
      "matchFileNames": ["apps/downloads/**"],
      "groupName": "downloads"
    },
    {
      "matchFileNames": ["apps/development/**"],
      "groupName": "development"
    },
    {
      "matchFileNames": ["apps/system/**"],
      "groupName": "system"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchPackageNames": ["linuxserver/qbittorrent"],
      "allowedVersions": "<=9"
    },
    {
      "matchPackageNames": ["linuxserver/jellyfin"],
      "allowedVersions": "<=19"
    },
    {
      "matchPackageNames": ["linuxserver/overseerr"],
      "allowedVersions": "<=9"
    }
  ]
}
