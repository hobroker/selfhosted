{
  "name": "@hobroker/selfhosted",
  "version": "1.1.0",
  "description": "A collection of tools and documentation for self-hosted applications",
  "author": "Igor Leahu <igor.leahu24@gmail.com>",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/catalog"
  ],
  "scripts": {
    "prepare": "husky",
    "generate": "tsx packages/catalog/src/cli.ts",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "turbo format",
    "format:check": "turbo format -- --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "turbo": "^2.8.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{md,yaml}": "prettier --write",
    "apps/**/README.partial.md": "bash -c 'npm run generate'",
    "apps/**/application.yaml": "bash -c 'npm run generate'"
  }
}
