{
  "name": "@hobroker/selfhosted",
  "version": "1.1.0",
  "description": "A collection of tools and documentation for self-hosted applications",
  "author": "Igor Leahu <igor.leahu24@gmail.com>",
  "packageManager": "npm@11.12.0",
  "workspaces": [
    "packages/catalog",
    "packages/dep-graph"
  ],
  "scripts": {
    "prepare": "husky",
    "generate": "tsx packages/catalog/src/cli.ts",
    "dep-graph": "tsx packages/dep-graph/src/cli.ts",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.19"
  }
}
