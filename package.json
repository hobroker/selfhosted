{
  "name": "@hobroker/selfhosted",
  "version": "1.1.0",
  "description": "A collection of tools and documentation for self-hosted applications",
  "author": "Igor Leahu <igor.leahu24@gmail.com>",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/catalog"
  ],
  "scripts": {
    "prepare": "husky",
    "generate": "tsx packages/catalog/src/cli.ts",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check ."
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.11",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{md,yaml}": "prettier --write",
    "apps/**/README.md": "bash -c 'npm run generate'"
  }
}
